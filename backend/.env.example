APP_NAME="AI Support Ops Platform"
ENVIRONMENT=development
DATABASE_URL=sqlite:///./data/support_ops.db
CHROMA_PATH=./data/chroma
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Use "heuristic" for offline demos or "groq" for production LLM inference.
AI_PROVIDER=heuristic
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Use Gemini embeddings for semantic retrieval when a key is available.
EMBEDDING_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

AI_CONFIDENCE_THRESHOLD=0.72
KB_MIN_RELEVANCE=0.42
SEED_DEMO_DATA=true
